public static int worstTimezoneFit(City c1, City c2) {
    double diff1 = Math.abs(c1.calculateDiff());
    double diff2 = Math.abs(c2.calculateDiff());
    return Double.compare(diff2, diff1); // diff2 pierwszy = malejąco [cite: 687]
}

